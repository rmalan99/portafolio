---
import ProjectShowcase from "@components/projects/ProjectShowcase.astro";
import ProjectFilters from "@components/projects/ProjectFilters.astro";
import { projectSectionCopy, PROJECTS } from "@consts/projects";

const isSpanish = Astro.url.pathname.startsWith("/es");
const copy = isSpanish ? projectSectionCopy.es : projectSectionCopy.en;

const filterOptions = copy.filters.map((label: string, idx: number) => {
  const values = ["all", "web", "mobile", "api"] as const;
  return { label, value: values[idx] ?? "all" };
});

const sectionShell =
  "mx-auto flex w-full max-w-7xl flex-col gap-12 px-6 sm:px-10 xl:px-0";
---

<section id="projects" class="relative w-full overflow-hidden bg-[var(--surface-section)] py-24 sm:py-28 lg:py-2" data-projects-root>
  <!-- Decorative dot pattern overlay -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,var(--text-accent)_1px,transparent_1px)] bg-[size:28px_28px] opacity-40"></div>

 

  <div class={sectionShell}>
    <!-- Section Header -->
    <div class="relative flex flex-col items-center text-center">
      <!-- Subtle sketch accent above eyebrow -->
    

      <!-- Title with highlighted word -->
      <h3 class="max-w-[32rem] text-[2rem] font-bold leading-[1.04] tracking-[-0.06em] text-[var(--text-primary)] sm:text-[2rem] lg:text-[2.25rem]">
        {copy.title}
      </h3>

      <!-- Subtitle -->
      <p class="mt-6 max-w-[30rem] text-[0.92rem] leading-[1.65] text-[var(--text-muted)] sm:text-[0.95rem]">
        {copy.description}
      </p>
    </div>

    <!-- Filters -->
    <div class="flex justify-center">
      <ProjectFilters filters={filterOptions} />
    </div>

    <!-- Project Grid -->
    <div class="grid grid-cols-1 gap-6 sm:gap-8 lg:grid-cols-2 lg:gap-10">
      {
        PROJECTS.map((project) => {
          const description = isSpanish ? project.descriptionEs : project.descriptionEn;
          const typeLabel = copy.projectType[project.type];
          const categoryLabel = copy.projectCategory[project.category];

          return (
            <ProjectShowcase
              project={project}
              description={description}
              typeLabel={typeLabel}
              categoryLabel={categoryLabel}
              sourceLabel={copy.source}
              demoLabel={copy.demo}
              mediaLabel={copy.mediaLabel}
              playLabel={copy.playLabel}
              closeLabel={copy.closeLabel}
            />
          );
        })
      }
    </div>

    <!-- Decorative bottom marker -->
    <div aria-hidden="true" class="flex justify-center">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[color-mix(in_srgb,var(--text-accent)_50%,transparent)]"></span>
    </div>
  </div>
</section>
