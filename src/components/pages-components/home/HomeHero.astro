---
import useLang from "@utils/useLang";
import Button from "@components/buttons/Button.astro";
import ButtonIcon from "@components/buttons/ButtonIcon.astro";
import Github from "@assets/icons/github.svg";
import Linkedin from "@assets/icons/linkedin.svg";
import sources from "@consts/sources";

const { t } = useLang(Astro.url);
---

<section
  id="start"
  class="relative grid min-h-[100svh] w-full place-items-center overflow-hidden bg-1 px-6 py-16 sm:px-10 sm:py-20 xl:px-0"
>
  <div class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-10 sm:grid-cols-2 sm:items-center">
    <div class="order-2 flex flex-col items-center justify-center gap-10 sm:order-1">
      <div class="flex flex-col gap-4">
        <h3
          class="text-[1.4rem] font-bold text-center sm:text-left sm:text-xl md:text-2xl lg:text-4xl"
        >
          {t("home.hero.greeting")}
          <br class="block sm:hidden" />
          <span class="text-3">{t("home.hero.nameHighlight")}</span>,
          <br />
          {t("home.hero.role")}
        </h3>
        <div class="flex items-center gap-3">
          <Button href="#contact" variant="black" size="sm"
            >{t("home.hero.primaryCta")}</Button
          >
          <div class="flex items-center gap-3">
            <ButtonIcon variant="black" href={sources.github} target="_blank">
              <Github />
            </ButtonIcon>
            <ButtonIcon variant="black" href={sources.linkedin} target="_blank">
              <Linkedin />
            </ButtonIcon>
          </div>
        </div>
      </div>
    </div>

    <div class="order-1 flex items-center justify-center sm:order-2">
      <img
        class="h-3/4 object-contain mask-linear sm:h-auto sm:size-3/4"
        src="/images/alan_hidalgo.webp"
        alt="Alan Hidalgo"
      />
    </div>
  </div>
</section>

<style>
  .mask-linear {
    mask-image: linear-gradient(black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(black 90%, transparent 100%);
  }
</style>
