---
import type { HTMLAttributes } from "astro/types";

type AnchorProps = HTMLAttributes<"a">;
type NativeButtonProps = HTMLAttributes<"button">;

export interface Props
  extends Omit<AnchorProps, "class" | "href">,
    Omit<NativeButtonProps, "class" | "type" | "disabled"> {
  variant?: "white" | "black";
  size?: "sm" | "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  disabled?: boolean;
}

const {
  variant = "black",
  size = "md",
  href,
  type = "button",
  class: className = "",
  disabled = false,
  ...rest
} = Astro.props;

const baseClasses =
  "group relative inline-flex shrink-0 items-center justify-center gap-2 overflow-hidden rounded-full border border-transparent font-primary text-center font-bold uppercase leading-none tracking-[0.12em] whitespace-nowrap select-none transition-all duration-300 [transition-timing-function:var(--ease-smooth)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--surface-page)] disabled:pointer-events-none disabled:opacity-50";

const variantClasses = {
  white:
    "bg-[var(--surface-card)] text-[var(--text-primary)] shadow-[var(--shadow-soft)] hover:-translate-y-0.5 hover:bg-[var(--surface-card-hover)] hover:shadow-[var(--shadow-soft-hover)] focus-visible:ring-[var(--border-accent)]",
  black:
    "bg-[var(--button-bg)] text-[var(--button-text)] shadow-[var(--shadow-button)] hover:-translate-y-0.5 hover:opacity-95 hover:shadow-[var(--shadow-button-hover)] focus-visible:ring-[var(--border-accent)]",
};

const sizeClasses = {
  sm: "min-h-11 px-5 text-[0.68rem] sm:px-6",
  md: "min-h-12 px-6 text-[0.72rem] sm:px-7",
  lg: "min-h-14 px-7 text-[0.78rem] sm:px-9",
};

const stateClasses = disabled ? "cursor-not-allowed" : "active:scale-[0.985]";
const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${stateClasses} ${className}`;

const isLink = Boolean(href);
const linkHref = disabled ? undefined : href;
---

{
  isLink ? (
    <a
      href={linkHref}
      class={classes}
      aria-disabled={disabled ? "true" : undefined}
      tabindex={disabled ? "-1" : undefined}
      {...rest}
    >
      <span class="relative z-10 inline-flex items-center justify-center gap-2">
        <slot />
      </span>
    </a>
  ) : (
    <button type={type} class={classes} disabled={disabled} {...rest}>
      <span class="relative z-10 inline-flex items-center justify-center gap-2">
        <slot />
      </span>
    </button>
  )
}

<style>
  a::after,
  button::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--button-shine);
    transform: translateX(-135%);
    transition: transform 0.7s var(--ease-smooth);
    pointer-events: none;
  }

  a:hover::after,
  button:hover::after,
  a:focus-visible::after,
  button:focus-visible::after {
    transform: translateX(135%);
  }
 </style>
