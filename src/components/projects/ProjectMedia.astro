---
import type { ProjectMedia } from "@consts/projects";

interface Props {
  media: ProjectMedia;
  projectTitle: string;
  playLabel: string;
  closeLabel: string;
}

const { media, projectTitle, playLabel, closeLabel } = Astro.props;
---

{
  media.kind === "image" ? (
    <img
      src={media.src}
      alt={media.alt}
      loading="lazy"
      decoding="async"
      class="block h-full w-full object-cover object-center"
    />
  ) : (
    <>
      <button
        type="button"
        data-video-trigger
        aria-label={`${playLabel}: ${media.title}`}
        class="group relative flex min-h-[340px] w-full cursor-pointer items-center justify-center border-0 p-0 transition-all duration-300"
        style={`background:${media.posterBackground ?? "#f5efe6"};--project-poster-size:${media.posterSize ?? "11rem"}`}
      >
        <span
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#000_1px,transparent_1px)] bg-[size:18px_18px] opacity-[0.025]"
        ></span>

        {
          media.poster ? (
            <>
              <span class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,252,247,0.16)_0%,rgba(247,239,228,0.08)_100%)]"></span>
              <span class="relative z-10 flex h-full w-full items-center justify-center">
                <img
                  src={media.poster}
                  alt={`${projectTitle} logo`}
                  loading="lazy"
                  class="pointer-events-none h-[var(--project-poster-size)] w-[var(--project-poster-size)] max-h-[84%] max-w-[84%] object-contain drop-shadow-[0_18px_32px_rgba(95,39,4,0.18)] transition-transform duration-300 group-hover:scale-[1.03]"
                  onerror={`this.onerror=null;this.src='${media.poster.replace('.png', '.svg')}'`}
                />
              </span>
              <span class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,transparent_58%,rgba(0,0,0,0.05)_100%)]"></span>
              <span class="pointer-events-none absolute inset-0 z-20 flex items-center justify-center">
                <span class="flex h-[54px] w-[54px] shrink-0 items-center justify-center rounded-full bg-black/75 shadow-[0_8px_24px_rgba(0,0,0,0.14)] transition-all duration-300 group-hover:scale-110 group-hover:bg-black group-hover:shadow-[0_12px_32px_rgba(0,0,0,0.22)]">
                  <svg
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                    class="ml-0.5 h-6 w-6 fill-white"
                  >
                    <polygon points="5,3 19,12 5,21" />
                  </svg>
                </span>
              </span>
            </>
          ) : (
            <span class="relative z-10 flex flex-col items-center gap-5">
              <span class="font-secondary text-4xl leading-none tracking-[-0.02em] text-[#8B6914] sm:text-5xl">
                {projectTitle}
              </span>
              <span class="flex h-[54px] w-[54px] shrink-0 items-center justify-center rounded-full bg-black/75 shadow-[0_8px_24px_rgba(0,0,0,0.14)] transition-all duration-300 group-hover:scale-110 group-hover:bg-black group-hover:shadow-[0_12px_32px_rgba(0,0,0,0.22)]">
                <svg
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  class="ml-0.5 h-6 w-6 fill-white"
                >
                  <polygon points="5,3 19,12 5,21" />
                </svg>
              </span>
            </span>
          )
        }
      </button>

      <dialog
        data-video-modal
        aria-label={media.title}
        class="fixed inset-0 m-auto max-h-[90vh] max-w-[90vw] overflow-hidden rounded-2xl border-0 bg-black p-0 shadow-[0_24px_60px_rgba(0,0,0,0.4)] backdrop:bg-black/70 backdrop:backdrop-blur-sm"
      >
        <div class="relative flex items-center justify-center">
          <button
            type="button"
            data-video-close
            aria-label={closeLabel}
            class="absolute right-3 top-3 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white backdrop-blur-sm transition-colors hover:bg-white/35 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60 focus-visible:ring-offset-2 focus-visible:ring-offset-black"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5 fill-current">
              <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />
            </svg>
          </button>

          <video
            src={media.src}
            controls
            playsinline
            preload="metadata"
            class="block max-h-[85vh] w-auto max-w-full"
          ></video>
        </div>
      </dialog>

      <script>
        function setupVideoModals() {
          document.querySelectorAll('[data-video-trigger]').forEach(function (trigger) {
            if (trigger.dataset.videoInitialized) return;
            trigger.dataset.videoInitialized = 'true';

            var modal = trigger.nextElementSibling;
            if (!modal || !modal.matches || !modal.matches('[data-video-modal]')) return;

            var video = modal.querySelector('video');
            var closeBtn = modal.querySelector('[data-video-close]');

            trigger.addEventListener('click', function () {
              modal.showModal();
              if (video) video.play();
            });

            var closeModal = function () {
              if (video) video.pause();
              modal.close();
            };

            if (closeBtn) closeBtn.addEventListener('click', closeModal);

            modal.addEventListener('click', function (e) {
              if (e.target === modal) closeModal();
            });

            if (video) {
              video.addEventListener('ended', function () {
                modal.close();
              });

              modal.addEventListener('close', function () {
                video.pause();
              });
            }
          });
        }

        setupVideoModals();
      </script>
    </>
  )
}
