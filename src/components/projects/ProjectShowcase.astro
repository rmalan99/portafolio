---
import Button from "@components/buttons/Button.astro";
import ButtonIcon from "@components/buttons/ButtonIcon.astro";
import ProjectMedia from "@components/projects/ProjectMedia.astro";
import type { ProjectCard } from "@consts/projects";
import { projectTypeStyles, projectCategoryStyles } from "@consts/projects";
import Github from "../../assets/icons/github.svg";

interface Props {
  project: ProjectCard;
  description: string;
  typeLabel: string;
  categoryLabel: string;
  sourceLabel: string;
  demoLabel: string;
  mediaLabel: string;
  playLabel: string;
  closeLabel: string;
}

const {
  project,
  description,
  typeLabel,
  categoryLabel,
  sourceLabel,
  demoLabel,
  mediaLabel,
  playLabel,
  closeLabel,
} = Astro.props;

const techChip =
  "inline-flex items-center rounded-full bg-[var(--surface-subtle)] px-[0.6rem] py-[0.25rem] text-[0.65rem] font-medium leading-none tracking-[0.01em] text-[var(--text-accent-strong)] transition-colors duration-200 group-hover/tech:bg-[var(--surface-card-hover)] sm:px-[0.7rem] sm:py-[0.3rem] sm:text-[0.7rem]";

const hasGithub = Boolean(project.githubUrl);
const hasOverview = Boolean(project.overviewUrl);

const isImage = project.media.kind === "image";
---

<article
  data-project-card
  data-project-type={project.type}
  class="group/card relative grid overflow-hidden rounded-2xl border border-[var(--border-subtle)] bg-[var(--surface-section)] shadow-[var(--shadow-elevated)] transition-all duration-[400ms] [transition-timing-function:var(--ease-smooth)] hover:-translate-y-[1px] hover:border-[var(--border-strong)] hover:shadow-[var(--shadow-elevated-hover)] lg:grid-cols-[5fr_4fr]"
>
  <!-- Subtle dot decoration on card corners -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -left-px -top-px h-3 w-3 rounded-br-full border-b border-r border-[color-mix(in_srgb,var(--border-strong)_30%,transparent)] bg-transparent"
  >
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-px -top-px h-3 w-3 rounded-bl-full border-b border-l border-[color-mix(in_srgb,var(--border-strong)_30%,transparent)] bg-transparent"
  >
  </div>

  <!-- Media Panel -->
  <div
    class="flex flex-col overflow-hidden bg-[var(--surface-panel)] lg:border-r lg:border-r-[var(--border-subtle)]"
  >
    <!-- Browser-style header bar -->
    <div
      class="flex h-7 shrink-0 items-center justify-between border-b border-[color-mix(in_srgb,var(--border-subtle)_40%,transparent)] bg-[var(--surface-panel-strong)] px-4"
    >
      <div class="flex gap-1.5" aria-hidden="true">
        <span
          class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"
        ></span>
        <span
          class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"
        ></span>
        <span
          class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"
        ></span>
      </div>
      <span
        class="text-[0.6rem] font-semibold uppercase tracking-[0.14em] text-[var(--text-muted)]"
      >
        {mediaLabel}
      </span>
    </div>

    <!-- Media content -->
    <div class="flex flex-1 bg-[var(--surface-card)]">
      {
        isImage ? (
          <img
            src={project.media.src}
            alt={project.media.alt}
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover object-center transition-transform duration-700 [transition-timing-function:var(--ease-smooth)] group-hover/card:scale-[1.02]"
          />
        ) : (
          <ProjectMedia
            media={project.media}
            projectTitle={project.title}
            playLabel={playLabel}
            closeLabel={closeLabel}
          />
        )
      }
    </div>
  </div>

  <!-- Content Panel -->
  <div class="flex flex-col justify-center gap-5 p-6 sm:p-7 lg:min-h-0">
    <!-- Type & Category badges -->
    <div class="flex flex-wrap items-center gap-2">
      <span
        class:list={[
          projectTypeStyles[project.type],
          "inline-flex items-center rounded-full border px-[0.6rem] py-[0.22rem] text-[0.6rem] font-bold uppercase tracking-[0.12em] sm:text-[0.62rem] sm:px-[0.7rem] sm:py-[0.25rem]",
        ]}
      >
        {typeLabel}
      </span>
      <span
        class:list={[
          projectCategoryStyles[project.category],
          "inline-flex items-center rounded-full border px-[0.6rem] py-[0.22rem] text-[0.6rem] font-bold uppercase tracking-[0.08em] sm:text-[0.62rem] sm:px-[0.7rem] sm:py-[0.25rem]",
        ]}
      >
        {categoryLabel}
      </span>
    </div>

    <!-- Title & Description -->
    <div class="space-y-2">
      <h4
        class="text-[1.45rem] font-bold leading-[1.1] tracking-[-0.03em] text-[var(--text-primary)] sm:text-[1.55rem]"
      >
        {project.title}
      </h4>
      <p
        class="max-w-[26rem] text-[0.82rem] leading-[1.6] text-[var(--text-muted)]"
      >
        {description}
      </p>
    </div>

    <!-- Tech chips -->
    <div class="flex flex-wrap gap-1.5">
      {
        project.technologies.map((tech) => (
          <span class:list={["group/tech", techChip]}>{tech}</span>
        ))
      }
    </div>

    <!-- Divider accent line -->
    <div
      aria-hidden="true"
      class="h-px w-14 bg-[color-mix(in_srgb,var(--border-strong)_40%,transparent)]"
    >
    </div>

    <!-- CTAs -->
    {
      (hasOverview || hasGithub) && (
        <div class="flex flex-wrap items-center gap-3">
          {hasGithub && (
            <ButtonIcon variant="white" href={project.githubUrl}>
              <Github />
            </ButtonIcon>
          )}
          {hasOverview && (
            <Button
              href={project.overviewUrl}
              size="sm"
              target="_blank"
              rel="noreferrer noopener"
            >
              {demoLabel}
              <svg
                viewBox="0 0 24 24"
                aria-hidden="true"
                class="h-3.5 w-3.5 stroke-current"
              >
                <path
                  d="M5 12h14M13 5l7 7-7 7"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                />
              </svg>
            </Button>
          )}
        </div>
      )
    }
  </div>
</article>
