---
import Button from "@components/buttons/Button.astro";
import ProjectMedia from "@components/projects/ProjectMedia.astro";
import type { ProjectCard } from "@consts/projects";
import { projectTypeStyles, projectCategoryStyles } from "@consts/projects";

interface Props {
  project: ProjectCard;
  description: string;
  typeLabel: string;
  categoryLabel: string;
  sourceLabel: string;
  demoLabel: string;
  mediaLabel: string;
  playLabel: string;
  closeLabel: string;
}

const {
  project,
  description,
  typeLabel,
  categoryLabel,
  sourceLabel,
  demoLabel,
  mediaLabel,
  playLabel,
  closeLabel,
} = Astro.props;

const techChip =
  "inline-flex items-center rounded-full bg-[#1c1812]/[0.05] px-[0.6rem] py-[0.25rem] text-[0.65rem] font-medium leading-none tracking-[0.01em] text-[#5c4f38] transition-colors duration-200 group-hover/tech:bg-[#1c1812]/[0.08] sm:px-[0.7rem] sm:py-[0.3rem] sm:text-[0.7rem]";

const hasGithub = Boolean(project.githubUrl);
const hasOverview = Boolean(project.overviewUrl);

const isImage = project.media.kind === "image";
---

<article
  data-project-card
  data-project-type={project.type}
  class="group/card relative grid overflow-hidden rounded-2xl border border-[#d9cebb]/70 bg-[var(--bg-2)] shadow-[0_1px_20px_rgba(100,70,30,0.04)] transition-all duration-[400ms] [transition-timing-function:var(--ease-smooth)] hover:-translate-y-[1px] hover:border-[#c9b896]/80 hover:shadow-[0_4px_32px_rgba(100,70,30,0.09)] lg:grid-cols-[5fr_4fr]"
>
  <!-- Subtle dot decoration on card corners -->
  <div aria-hidden="true" class="pointer-events-none absolute -left-px -top-px h-3 w-3 rounded-br-full border-b border-r border-[#c9b896]/30 bg-transparent"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -right-px -top-px h-3 w-3 rounded-bl-full border-b border-l border-[#c9b896]/30 bg-transparent"></div>

  <!-- Media Panel -->
  <div class="flex flex-col overflow-hidden bg-[color-mix(in_srgb,var(--bg-2)_94%,#8b6914)] lg:border-r lg:border-r-[#d9cebb]/70">
    <!-- Browser-style header bar -->
    <div class="flex h-7 shrink-0 items-center justify-between border-b border-[#d9cebb]/40 bg-[color-mix(in_srgb,var(--bg-2)_88%,white)] px-4">
      <div class="flex gap-1.5" aria-hidden="true">
        <span class="h-2.5 w-2.5 rounded-full bg-[#d6c29f]/70"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#d6c29f]/70"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[#d6c29f]/70"></span>
      </div>
      <span class="text-[0.6rem] font-semibold uppercase tracking-[0.14em] text-[#9b896a]">
        {mediaLabel}
      </span>
    </div>

    <!-- Media content -->
    <div class="flex flex-1 bg-[color-mix(in_srgb,var(--bg-2)_96%,#8b6914)]">
      {
        isImage ? (
          <img
            src={project.media.src}
            alt={project.media.alt}
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover object-center transition-transform duration-700 [transition-timing-function:var(--ease-smooth)] group-hover/card:scale-[1.02]"
          />
        ) : (
          <ProjectMedia
            media={project.media}
            projectTitle={project.title}
            playLabel={playLabel}
            closeLabel={closeLabel}
          />
        )
      }
    </div>
  </div>

  <!-- Content Panel -->
  <div class="flex flex-col justify-center gap-5 p-6 sm:p-7 lg:min-h-0">
    <!-- Type & Category badges -->
    <div class="flex flex-wrap items-center gap-2">
      <span
        class:list={[
          projectTypeStyles[project.type],
          "inline-flex items-center rounded-full border px-[0.6rem] py-[0.22rem] text-[0.6rem] font-bold uppercase tracking-[0.12em] sm:text-[0.62rem] sm:px-[0.7rem] sm:py-[0.25rem]",
        ]}
      >
        {typeLabel}
      </span>
      <span
        class:list={[
          projectCategoryStyles[project.category],
          "inline-flex items-center rounded-full border px-[0.6rem] py-[0.22rem] text-[0.6rem] font-bold uppercase tracking-[0.08em] sm:text-[0.62rem] sm:px-[0.7rem] sm:py-[0.25rem]",
        ]}
      >
        {categoryLabel}
      </span>
    </div>

    <!-- Title & Description -->
    <div class="space-y-2">
      <h4 class="text-[1.45rem] font-bold leading-[1.1] tracking-[-0.03em] text-[#1c1812] sm:text-[1.55rem]">
        {project.title}
      </h4>
      <p class="max-w-[26rem] text-[0.82rem] leading-[1.6] text-[#6b5e4c]">
        {description}
      </p>
    </div>

    <!-- Tech chips -->
    <div class="flex flex-wrap gap-1.5">
      {project.technologies.map((tech) => (
        <span class:list={["group/tech", techChip]}>{tech}</span>
      ))}
    </div>

    <!-- Divider accent line -->
    <div aria-hidden="true" class="h-px w-14 bg-[#c9b896]/40"></div>

    <!-- CTAs -->
    {
      (hasOverview || hasGithub) && (
        <div class="flex flex-wrap items-center gap-3">
          {
            hasOverview && (
              <Button
                href={project.overviewUrl}
                size="sm"
                target="_blank"
                rel="noreferrer noopener"
              >
                {demoLabel}
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5 stroke-current">
                  <path
                    d="M5 12h14M13 5l7 7-7 7"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                  ></path>
                </svg>
              </Button>
            )
          }
          {
            hasGithub && (
              <Button
                href={project.githubUrl}
                size="sm"
                variant="white"
                target="_blank"
                rel="noreferrer noopener"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5 fill-current">
                  <path d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.43 7.88 10.95.58.1.8-.25.8-.56 0-.27-.01-1.18-.02-2.13-3.21.7-3.89-1.36-3.89-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.15.08 1.76 1.19 1.76 1.19 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.72-1.55-2.56-.29-5.26-1.29-5.26-5.74 0-1.27.45-2.3 1.18-3.11-.12-.29-.51-1.47.12-3.06 0 0 .96-.31 3.15 1.19a10.9 10.9 0 0 1 5.74 0c2.19-1.5 3.15-1.19 3.15-1.19.63 1.59.24 2.77.12 3.06.74.81 1.18 1.84 1.18 3.11 0 4.47-2.7 5.44-5.27 5.73.41.36.78 1.06.78 2.15 0 1.56-.01 2.82-.01 3.2 0 .31.21.67.81.56A11.54 11.54 0 0 0 23.5 12.03C23.5 5.66 18.35.5 12 .5Z"></path>
                </svg>
                {sourceLabel}
              </Button>
            )
          }
        </div>
      )
    }
  </div>
</article>
