---
import Button from "@components/buttons/Button.astro";
import ProjectMedia from "@components/projects/ProjectMedia.astro";
import type { ProjectCard } from "@consts/projects";
import { projectTypeStyles, projectCategoryStyles } from "@consts/projects";

interface Props {
  project: ProjectCard;
  description: string;
  typeLabel: string;
  categoryLabel: string;
  sourceLabel: string;
  demoLabel: string;
  mediaLabel: string;
  playLabel: string;
  closeLabel: string;
}

const {
  project,
  description,
  typeLabel,
  categoryLabel,
  sourceLabel,
  demoLabel,
  mediaLabel,
  playLabel,
  closeLabel,
} = Astro.props;

const tagPill =
  "inline-flex items-center rounded-full border border-[var(--border-subtle)] bg-[var(--surface-subtle)] px-3 py-1.5 text-[11px] font-medium leading-none text-[var(--text-accent-strong)]";
const surfaceCard =
  "rounded-2xl border border-[var(--border-subtle)] bg-[var(--surface-card)] shadow-[var(--shadow-elevated)]";

const isVideo = project.media.kind === "video";
---

<article
  data-project-card
  data-project-type={project.type}
  class:list={[
    surfaceCard,
    "grid gap-0 overflow-hidden",
    "lg:grid-cols-[minmax(0,0.70fr)_minmax(0,0.50fr)] lg:items-stretch rounded-[27px]",
  ]}
>

  <div
    class="flex flex-col justify-center overflow-hidden rounded-t-[26px] border-b border-[var(--border-subtle)] bg-[var(--surface-panel)] lg:rounded-l-[26px] lg:rounded-r-none lg:border-b-0 lg:border-r"
  >
    <div
      class="flex h-6 shrink-0 items-center justify-between border-b border-[color-mix(in_srgb,var(--border-subtle)_40%,transparent)] bg-[var(--surface-panel-strong)] px-4"
    >
      <div class="flex gap-1.5" aria-hidden="true">
        <span class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-[color-mix(in_srgb,var(--border-strong)_70%,transparent)]"></span>
      </div>
      <span class="text-[0.6rem] font-semibold uppercase tracking-[0.16em] text-[var(--text-muted)]">
        {mediaLabel}
      </span>
    </div>

    <div class="flex flex-1 bg-[var(--surface-card)]">
      {
        isVideo ? (
          <ProjectMedia
            media={project.media}
            projectTitle={project.title}
            playLabel={playLabel}
            closeLabel={closeLabel}
          />
        ) : (
          <img
            src={project.media.src}
            alt={project.media.alt}
            loading="lazy"
            decoding="async"
            class="block h-full w-full object-cover object-center"
          />
        )
      }
    </div>
  </div>

  <div class="flex flex-col justify-center gap-5 p-6 sm:p-8">
    <div class="flex flex-wrap items-center gap-2.5">
      <span
        class:list={[
          "inline-flex items-center rounded-full border px-3.5 py-1.5 text-[11px] font-bold uppercase tracking-[0.12em]",
          projectTypeStyles[project.type],
        ]}
      >
        {typeLabel}
      </span>
      <span
        class:list={[
          "inline-flex items-center rounded-full border px-3.5 py-1.5 text-[11px] font-bold",
          projectCategoryStyles[project.category],
        ]}
      >
        {categoryLabel}
      </span>
    </div>

    <div class="space-y-3">
      <h4 class="font-display text-[1.55rem] font-bold leading-[1.05] tracking-[-0.04em] text-[var(--text-primary)] sm:text-[1.65rem]">
        {project.title}
      </h4>
      <p class="max-w-[22rem] text-[0.85rem] leading-[1.55] text-[var(--text-muted)]">
        {description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      {project.technologies.map((tech) => <span class={tagPill}>{tech}</span>)}
    </div>

    <div class="mt-auto flex flex-wrap gap-3 pt-1">
      {project.overviewUrl && (
        <Button href={project.overviewUrl} size="sm" target="_blank" rel="noreferrer noopener">
          {demoLabel}
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 stroke-current">
            <path
              d="M5 12h14M13 5l7 7-7 7"
              fill="none"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.9"
            ></path>
          </svg>
        </Button>
      )}
      {project.githubUrl && (
        <Button href={project.githubUrl} size="sm" variant="white" target="_blank" rel="noreferrer noopener">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-current">
            <path d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.43 7.88 10.95.58.1.8-.25.8-.56 0-.27-.01-1.18-.02-2.13-3.21.7-3.89-1.36-3.89-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.15.08 1.76 1.19 1.76 1.19 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.72-1.55-2.56-.29-5.26-1.29-5.26-5.74 0-1.27.45-2.3 1.18-3.11-.12-.29-.51-1.47.12-3.06 0 0 .96-.31 3.15 1.19a10.9 10.9 0 0 1 5.74 0c2.19-1.5 3.15-1.19 3.15-1.19.63 1.59.24 2.77.12 3.06.74.81 1.18 1.84 1.18 3.11 0 4.47-2.7 5.44-5.27 5.73.41.36.78 1.06.78 2.15 0 1.56-.01 2.82-.01 3.2 0 .31.21.67.81.56A11.54 11.54 0 0 0 23.5 12.03C23.5 5.66 18.35.5 12 .5Z"></path>
          </svg>
          {sourceLabel}
        </Button>
      )}
    </div>
  </div>
</article>
